{
  "name": "kodkong",
  "version": "1.0.0",
  "private": true,
  "description": "Japanese product ordering platform with real-time tracking - Monorepo",
  "author": "KodKong Team",
  "license": "MIT",
  "keywords": [
    "e-commerce",
    "japanese-products",
    "order-tracking",
    "monorepo",
    "nextjs",
    "express"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "PATH=$HOME/Library/pnpm:$PATH turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "lint:fix": "turbo lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @kodkong/database db:migrate",
    "db:migrate:dev": "pnpm --filter @kodkong/database db:migrate:dev",
    "db:push": "pnpm --filter @kodkong/database db:push",
    "db:seed": "pnpm --filter @kodkong/database db:seed",
    "db:studio": "pnpm --filter @kodkong/database db:studio",
    "db:reset": "pnpm --filter @kodkong/database db:reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "eslint": "^8.56.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^1.12.5",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
