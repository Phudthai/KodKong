# ==============================================
# KodKong - Git Ignore File
# ==============================================

# ==============================================
# Environment Variables
# ==============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==============================================
# Dependencies
# ==============================================
node_modules/
.pnp
.pnp.js

# ==============================================
# Testing
# ==============================================
coverage/
.nyc_output/
*.lcov

# ==============================================
# Next.js
# ==============================================
.next/
out/
build/
dist/

# ==============================================
# Production
# ==============================================
.vercel

# ==============================================
# Debug
# ==============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==============================================
# IDEs and Editors
# ==============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ==============================================
# OS Files
# ==============================================
Thumbs.db

# ==============================================
# TypeScript
# ==============================================
*.tsbuildinfo
next-env.d.ts

# ==============================================
# Logs
# ==============================================
logs/
*.log

# ==============================================
# Docker Volumes (optional)
# ==============================================
# postgres_data/
# redis_data/
# pgadmin_data/

# ==============================================
# Temporary Files
# ==============================================
tmp/
temp/
*.tmp

# ==============================================
# Uploads (if stored locally)
# ==============================================
uploads/
public/uploads/

# ==============================================
# Database Backups
# ==============================================
*.sql.gz
*.sql.backup
backups/

# ==============================================
# Sentry
# ==============================================
.sentryclirc

# ==============================================
# Test Files
# ==============================================
test-results/
playwright-report/
playwright/.cache/
