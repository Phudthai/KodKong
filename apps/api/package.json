{
  "name": "@kodkong/api",
  "version": "1.0.0",
  "private": true,
  "description": "KodKong Express Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "echo 'API uses tsx at runtime — no build step needed'",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@kodkong/database": "workspace:*",
    "@kodkong/shared": "workspace:*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "tsx": "^4.7.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3"
  }
}
