# ==============================================
# KodKong — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ==============================================

# --- Node ---
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local Docker:  postgresql://kodkong:kodkong_dev_password@localhost:5432/kodkong_dev
# Railway:       automatically injected as DATABASE_URL
# Neon:          postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://kodkong:kodkong_dev_password@localhost:5432/kodkong_dev

# --- Redis ---
# Local Docker:  redis://:kodkong_redis_password@localhost:6379
# Railway:       automatically injected as REDIS_URL
# Upstash:       rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://:kodkong_redis_password@localhost:6379

# --- Auth (JWT) ---
# Generate a strong secret:  openssl rand -base64 32
JWT_SECRET=kodkong-dev-secret-change-in-production

# --- API ---
API_PORT=4000

# --- Docker Compose (local dev only) ---
POSTGRES_DB=kodkong_dev
POSTGRES_USER=kodkong
POSTGRES_PASSWORD=kodkong_dev_password
POSTGRES_PORT=5432
REDIS_PASSWORD=kodkong_redis_password
REDIS_PORT=6379

# --- Vercel (auto-injected, only needed for local preview) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000
