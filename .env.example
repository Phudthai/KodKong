# ==============================================
# KodKong - Environment Variables Template
# ==============================================
# คัดลอกไฟล์นี้เป็น .env และแก้ไขค่าตามต้องการ
# Copy this file to .env and modify values as needed

# ==============================================
# Database Configuration (PostgreSQL)
# ==============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kodkong_dev
POSTGRES_USER=kodkong
POSTGRES_PASSWORD=kodkong_dev_password

# Database Connection URL (used by application)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# Redis Configuration
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=kodkong_redis_password

# Redis Connection URL (used by application)
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ==============================================
# Application Configuration
# ==============================================
NODE_ENV=development
PORT=3000
API_PORT=4000

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ==============================================
# JWT & Authentication
# ==============================================
# Generate secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRES_IN=30d

# ==============================================
# Session Configuration
# ==============================================
SESSION_SECRET=your-super-secret-session-key-change-this
SESSION_MAX_AGE=604800000  # 7 days in milliseconds

# ==============================================
# Payment Gateway (Omise)
# ==============================================
# Get from: https://dashboard.omise.co/test/api-keys
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxxxx
OMISE_API_VERSION=2019-05-29

# ==============================================
# Currency Exchange Rate API
# ==============================================
# Get free key from: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your-api-key-here
EXCHANGE_RATE_BASE_CURRENCY=JPY

# ==============================================
# Email Service (SendGrid)
# ==============================================
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@kodkong.com
SENDGRID_FROM_NAME=KodKong

# ==============================================
# LINE Integration (Optional - Phase 8)
# ==============================================
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_NOTIFY_TOKEN=your-line-notify-token

# ==============================================
# File Storage (AWS S3 or Cloudinary)
# ==============================================
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=kodkong-uploads

# Cloudinary (Alternative)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ==============================================
# Error Tracking & Monitoring (Sentry)
# ==============================================
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-organization
SENTRY_PROJECT=kodkong

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests per minute

# ==============================================
# CORS Configuration
# ==============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# ==============================================
# Admin Panel (Optional)
# ==============================================
# pgAdmin (Web-based PostgreSQL GUI)
PGADMIN_EMAIL=admin@kodkong.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ==============================================
# Feature Flags
# ==============================================
ENABLE_REGISTRATION=true
ENABLE_LINE_LOGIN=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REAL_TIME_TRACKING=true

# ==============================================
# Development Tools
# ==============================================
# Enable debug logging
DEBUG=kodkong:*

# Enable TypeScript type checking
TYPECHECK=true

# ==============================================
# Production Settings (Change in production)
# ==============================================
# NODE_ENV=production
# POSTGRES_PASSWORD=use-strong-password-here
# REDIS_PASSWORD=use-strong-password-here
# JWT_SECRET=generate-with-openssl-rand-base64-32
# SESSION_SECRET=generate-with-openssl-rand-base64-32
